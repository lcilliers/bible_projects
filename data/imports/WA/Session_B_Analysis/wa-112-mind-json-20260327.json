  "dimensions": {
    "relational_environment": {
      "present": true,
      "note": "All four rings active. Ring 1 dominates. Ring 2 substantially present (God remembers, searches minds, renews the nous, writes law on dianoia, gives mind of Christ). Ring 3 present through shared-mind vocabulary, remembrance in prayer, conscience in community. Ring 4 marginal through noēma (Satan's designs on the mind)."
    },
    "spirit_soul_body": {
      "present": true,
      "note": "Mind operates primarily at soul-level. Spirit-mind distinction explicit in 1 Cor 14:14-15 (nous vs pneuma in prayer). Body appears as instrument and marker of mind-states. Somatic-attention connection implicit throughout sha.mar corpus."
    },
    "inner_operations": {
      "present": true,
      "note": "Full range documented: remembering and forgetting; planning and devising; inclining and orienting; evaluating from within (conscience); changing (metanoeō, na.cham); collapsing into madness or maintaining sobriety; attending deliberately. Renewal of the mind (Rom 12:2) is the most distinctive inner operation."
    },
    "being": {
      "present": true,
      "note": "Ye.tser (formed inclination) is the primary dispositional Hebrew term. Sōfrōn family documents formed character of sound-mindedness. Froneō operates as characterising disposition in Phil 2:5. Mind of Christ (1 Cor 2:16) is the supreme example of transferred orientation of being."
    }
  },
  "inner_being_standing": {
    "classification": "confirmed_characteristic",
