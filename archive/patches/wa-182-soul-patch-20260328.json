    {
      "op_id": "OP-024",
      "operation": "insert",
      "table": "wa_session_b_dimensions",
      "record": {
        "registry_id": 182,
        "file_id": 36,
        "relational_environment": 1,
        "relational_environment_note": "All four rings active. Ring 1 dominates — soul as the inner experiential centre. Ring 2 substantially present: God creates soul (Gen 2:7), owns all souls (Eze 18:4), redeems/preserves/requires the soul, refreshes (Exo 31:17), Christ as Shepherd and Overseer of souls (1Pe 2:25). Ring 3 present through soul-to-soul bonding (1Sa 18:1), corporate soul-unity (Act 4:32), sumpsuchos and isopsuchos (Phi 2:2,20). Ring 4 marginal.",
        "spirit_soul_body": 1,
        "spirit_soul_body_note": "Soul is the primary term of Circle Two by definition. Spirit-soul boundary established by G5591 psuchikos (soul without Spirit = natural/creaturely mode) and Heb 4:12 (Word divides soul and spirit). Soul-body boundary collapses: ne.phesh IS the animated body, not a component within it. 1Th 5:23 tripartite preservation. 1Co 15:44-46 eschatological trajectory: psuchikon → pneumatikon.",
        "inner_operations": 1,
        "inner_operations_note": "Full range documented: desiring and craving (H5315L), experiencing emotion (H5315G — cast down, bitter, joyful), self-address and reflexive observation (Psa 42:5), soul-to-soul bonding (1Sa 18:1), soul departing at death (G1634, Gen 35:18), soul-refreshment (H5314), soul fainting under pressure (G0674), double-mindedness (G1374). The soul's self-address (commanding its own hope) is its most distinctive inner operation.",
        "being": 1,
        "being_note": "Soul as identity — the self that persists, is threatened, can be lost and found (Mat 10:39). Soul as moral accountability — Eze 18:4 soul who sins shall die. Soul as object of salvation (1Pe 1:9). Soul as created appetite — constitutively oriented toward something; the question is always the object of orientation. Dipsuchos documents the soul's division as a character condition, not merely an event.",
        "raised_date": "2026-03-28",
        "session_b_instruction": "WA-SessionB-Extraction-Instruction-v5.2"
      },
      "description": "Dimensional profile for registry 182 — all four dimensions active"
    },
