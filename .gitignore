# ─────────────────────────────────────────────
# Bible_Projects – .gitignore
# ─────────────────────────────────────────────

# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
env/
venv/
.venv/
ENV/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Jupyter Notebooks ─────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Data files (large / generated) ────────────
data/*.db
data/*.sqlite
data/*.sqlite3
data/*.bak
data/*.bak_*

# ── Live database (analytics folder) ──────────
analytics/*.db
analytics/*.sqlite
analytics/*.sqlite3

# ── Backups folder ────────────────────────────
backups/

# ── SQLite import / export staging files ──────
# (these are transient; commit only the schema and .gitkeep files)
data/imports/*.json
data/exports/*.json
!data/exports/database_schema_*.json
!data/exports/wa-registry-overview-*.json
data/exports/*.csv

# ── Generated word report CSVs ────────────────
outputs/word_reports/

# ── Output binaries (track only source .md) ───
outputs/docx/*.docx
outputs/pdf/*.pdf

# ── Research: large / binary files stay on Google Drive ─
# Text notes (.md) ARE tracked in Git.
# PDFs, Word docs, HTML exports, images are NOT.
research/**/*.pdf
research/**/*.docx
research/**/*.doc
research/**/*.html
research/**/*.htm
research/**/*.png
research/**/*.jpg
research/**/*.jpeg
research/**/*.gif
research/**/*.xlsx
research/**/*.xls

# ── PowerShell ────────────────────────────────
*.ps1xml

# ── Environment / secrets ─────────────────────
.env
.env.*
*.env
config/secrets.json
config/api_keys.json
zotero_api_key.txt

# ── OS artefacts ──────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
~$*

# ── Visual Studio / VS Code ───────────────────
.vs/
.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates

# ── Obsidian ──────────────────────────────────
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# ── Zotero (local cache) ──────────────────────
zotero-cache/

# ── Misc ──────────────────────────────────────
*.log
*.tmp
*.bak
*.swp
*~

# Claude Code local settings
.claude/settings.local.json
.claude/worktrees/
outputs/reports/words/love_full_extract.csv
