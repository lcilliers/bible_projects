# ─────────────────────────────────────────────
# Bible_Projects – .gitignore
# ─────────────────────────────────────────────

# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
env/
venv/
.venv/
ENV/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Jupyter Notebooks ─────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Data files (large / generated) ────────────
data/*.db
data/*.sqlite
data/*.sqlite3
data/*.bak
data/*.bak_*

# ── Live database (post-2026-04-27 restructure) ──
# DB now lives in database/; file_manifest.json is small and stays tracked.
database/*.db
database/*.sqlite
database/*.sqlite3
database/*.bak
database/*.bak_*

# ── Legacy paths (kept for safety) ────────────
analytics/*.db
analytics/*.sqlite
analytics/*.sqlite3
scripts/analytics/*.db
scripts/analytics/*.sqlite
scripts/analytics/*.sqlite3
scripts/database/

# ── Backups folder ────────────────────────────
backups/

# ── SQLite import / export staging files ──────
# (these are transient; commit only the schema and .gitkeep files)
data/imports/*.json
data/exports/*.json
!data/exports/database_schema_*.json
!data/exports/wa-registry-overview-*.json
data/exports/*.csv

# ── Generated word report CSVs ────────────────
outputs/word_reports/

# ── Output binaries (track only source .md) ───
outputs/docx/*.docx
outputs/pdf/*.pdf

# ── Research: large / binary files stay on Google Drive ─
# Text notes (.md) ARE tracked in Git.
# PDFs, Word docs, HTML exports, images are NOT.
research/**/*.pdf
research/**/*.docx
research/**/*.doc
research/**/*.html
research/**/*.htm
research/**/*.png
research/**/*.jpg
research/**/*.jpeg
research/**/*.gif
research/**/*.xlsx
research/**/*.xls

# ── PowerShell ────────────────────────────────
*.ps1xml

# ── Environment / secrets ─────────────────────
.env
.env.*
*.env
config/secrets.json
config/api_keys.json
zotero_api_key.txt

# ── OS artefacts ──────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
~$*

# ── Visual Studio / VS Code ───────────────────
.vs/
.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates

# ── Obsidian ──────────────────────────────────
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# ── Zotero (local cache) ──────────────────────
zotero-cache/

# ── Misc ──────────────────────────────────────
*.log
*.tmp
*.bak
*.swp
*~

# Claude Code local settings
.claude/settings.local.json
.claude/worktrees/
.claude/*.lock

# ── Large extract artefacts (legacy + post-restructure paths) ─
outputs/reports/words/love_full_extract.csv
outputs/reports/words/*_full_extract.csv
outputs/reports/words/*.log
Sessions/Session_B/09_Analysis_output_logs/words/love_full_extract.csv
Sessions/Session_B/09_Analysis_output_logs/words/*_full_extract.csv
Sessions/Session_B/09_Analysis_output_logs/words/*.log
**/*_full_extract.csv

# ── Session-Cluster AI handoff zips (transient — content is unpacked into folders) ─
Sessions/Session_Clusters/**/*.zip

# CC verse-read transient handshake files
outputs/cc/cc_packets.md
outputs/cc/cc_packets.md.map
outputs/cc/cc_output.md

# VE-lexical AI extracts (regenerable, large)
research/VE-lexical/extracts/
# per-cluster regenerable VE data (extracts + read-payloads; large). by-characteristic JSON stays tracked.
Sessions-v2/*/Data/wa-ve-lexical-extract-*.json
Sessions-v2/*/Data/archive/wa-ve-lexical-extract-*.json
Sessions-v2/*/Data/cause-api-*.json
Sessions-v2/*/Data/field-api-*.json

# Sessions-v2 AI handoff zips (transient — unpacked into folders)
Sessions-v2/**/*.zip
database/*.db-journal
